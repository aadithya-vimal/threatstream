# API
PROJECT_NAME=ThreatStream Application Security API
API_V1_STR=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:5173

# PostgreSQL. Runtime accepts standard Neon URLs and normalizes them to asyncpg.
DATABASE_URL=postgresql://user:password@pooled-host/database?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@direct-host/database?sslmode=require
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
SCAN_WORKER_POLL_SECONDS=3
SCAN_WORKER_LEASE_SECONDS=90
SCAN_WORKER_HEARTBEAT_SECONDS=20
SCAN_WORKER_RECOVERY_SECONDS=30
SCAN_WORKER_SHUTDOWN_GRACE_SECONDS=30
SCAN_WORKER_CONCURRENCY=1
SCAN_JOB_MAX_ATTEMPTS=3

# Neon Auth backend verification. These values must belong to the database branch.
NEON_AUTH_ISSUER=https://your-branch-auth-issuer.example
NEON_AUTH_JWKS_URL=https://your-branch-jwks-endpoint.example
# Leave empty when issued tokens do not require audience validation.
NEON_AUTH_AUDIENCE=
NEON_AUTH_JWT_ALGORITHMS=EdDSA,RS256,ES256
NEON_AUTH_JWKS_CACHE_SECONDS=300
NEON_AUTH_JWKS_TIMEOUT_SECONDS=3.0

# Encryption infrastructure for workspace credentials entered through Settings.
# Provider API keys do not belong in this file.
CREDENTIAL_ENCRYPTION_KEY=base64url-encoded-32-byte-key
CREDENTIAL_KEY_VERSION=1
