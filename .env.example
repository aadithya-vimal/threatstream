ENVIRONMENT=development
PROJECT_NAME=ThreatStream Application Security API
API_V1_STR=/api/v1

# PostgreSQL. Keep real URLs in backend/.env or process environment only.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@host/database?sslmode=require
DATABASE_ECHO=false

# Neon Auth. All values must belong to the same Neon development branch.
VITE_NEON_AUTH_URL=https://your-branch-auth-endpoint.example
NEON_AUTH_ISSUER=https://your-branch-auth-issuer.example
NEON_AUTH_JWKS_URL=https://your-branch-jwks-endpoint.example
# Set only when the issued JWT contains an audience that must be enforced.
NEON_AUTH_AUDIENCE=

VITE_API_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:5173

CREDENTIAL_ENCRYPTION_KEY=base64url-encoded-32-byte-key
CREDENTIAL_KEY_VERSION=1
