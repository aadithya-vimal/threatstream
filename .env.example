ENVIRONMENT=development
PROJECT_NAME=ThreatStream Application Security API
API_V1_STR=/api/v1

# PostgreSQL. Cloud uses Neon; self-hosting may use any compatible PostgreSQL server.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@host/database?sslmode=require
DATABASE_ECHO=false

# Clerk identity verification. The secret key is not required by the current JWT/JWKS implementation.
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=threatstream
CLERK_AUTHORIZED_PARTY=http://localhost:5173
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

VITE_API_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:5173
CREDENTIAL_ENCRYPTION_KEY=base64url-encoded-32-byte-key
CREDENTIAL_KEY_VERSION=1
