ENVIRONMENT=development
PROJECT_NAME=ThreatStream Application Security API
API_V1_STR=/api/v1

# PostgreSQL. Keep real URLs in backend/.env or process environment only.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@host/database?sslmode=require
DATABASE_ECHO=false

# Authentication values will be updated after the official Neon Auth SDK contract is verified.
VITE_API_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:5173

CREDENTIAL_ENCRYPTION_KEY=base64url-encoded-32-byte-key
CREDENTIAL_KEY_VERSION=1
